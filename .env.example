# VITAL AI — client environment.
# Copy to `.env` and fill in. Never commit `.env`.
#
# Only EXPO_PUBLIC_* vars reach the client bundle, so treat every value here as
# public. Secrets (service keys, model API keys) belong on the backend only.

EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
